ARG GO_VERSION=1.26

FROM golang:${GO_VERSION}-bookworm AS build

ARG GOPROXY=https://proxy.golang.org,direct
ARG GOSUMDB=sum.golang.org
ENV GOPROXY=${GOPROXY}
ENV GOSUMDB=${GOSUMDB}

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG TARGETOS
ARG TARGETARCH
RUN CGO_ENABLED=0 \
    GOOS=${TARGETOS:-linux} \
    GOARCH=${TARGETARCH:-amd64} \
    go build -trimpath -ldflags="-s -w" -o /out/captcha-server ./cmd/captcha-server
RUN mkdir -p /out/etc /out/tmp \
    && printf 'captcha:x:10001:10001:Captcha:/nonexistent:/sbin/nologin\n' > /out/etc/passwd \
    && printf 'captcha:x:10001:\n' > /out/etc/group \
    && chmod 1777 /out/tmp

FROM scratch

WORKDIR /app

COPY --from=build /out/etc/passwd /etc/passwd
COPY --from=build /out/etc/group /etc/group
COPY --from=build /out/tmp /tmp
COPY --from=build /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=build /out/captcha-server /usr/local/bin/captcha-server
COPY migrations ./migrations
COPY configs ./configs

USER captcha

EXPOSE 8080 9090

ENTRYPOINT ["captcha-server"]
